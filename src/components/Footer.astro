---
import Logo from "./Logo.astro";

const year = new Date().getFullYear();
const roman = (y: number) => {
  const map: [number, string][] = [
    [1000, "M"], [900, "CM"], [500, "D"], [400, "CD"],
    [100, "C"], [90, "XC"], [50, "L"], [40, "XL"],
    [10, "X"], [9, "IX"], [5, "V"], [4, "IV"], [1, "I"],
  ];
  let out = "";
  for (const [n, s] of map) { while (y >= n) { out += s; y -= n; } }
  return out;
};
---

<footer class="site-foot" id="visit">
  <h3 class="foot-big">
    Come <em>breathe</em> with us. <a href="mailto:hello@studio17staffs.co.uk">→ hello@studio17staffs.co.uk</a>
  </h3>

  <div class="foot-col">
    <h4>Visit</h4>
