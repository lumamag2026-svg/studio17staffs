---
import { portraits } from "../data/images";

const team = [
  {
    name: "Emma",
    role: "Founder · Head Instructor",
    photo: portraits[0],
    bio: "Studio 17 is Emma's studio. Married to Ian, mum to two teenagers and Phoebe the black lab, she opened the room with one idea: a reformer studio in Westbury Park where no one is ever left in the back row.",
    quals: [
      "Level 3 Reformer Pilates",
      "Level 3 Mat Pilates",
      "Level 2 & 3 Personal Trainer",
      "Level 2 & 3 Children's PT",
      "Level 2 & 3 Nutrition",
      "Menopause Trained",
      "First Aid",
    ],
  },
  {
    name: "Ruby",
    role: "Instructor",
    photo: portraits[0],
    bio: "Ruby brings a dance-trained eye for movement. She teaches with the same careful, classical approach as Emma, with a soft spot for clients getting back to feeling strong.",
    quals: [
      "Level 3 Reformer Pilates",
      "Level 3 Mat Pilates",
      "Level 3 Diploma in Dance",
      "First Aid",
    ],
  },
];
---

<section class="team tint" id="emma">
  <div class="sec-label reveal">
    <span class="num">05 / Teachers</span>
    <h2>Meet <em>Emma</em> and <em>Ruby</em>.</h2>
  </div>

  <div class="team-grid">
    {team.map((m, i) => (
      <article class="team-member reveal">
        <div class="tm-photo">
          <div class="ph">
            <img src={m.photo} alt={`${m.name}, ${m.role} at Studio 17`} loading="lazy" />
            <span class="ph-label"><span class="sq"></span> {m.role}</span>
            <span class="ph-tag">IMG · 0{5 + i}</span>
          </div>
        </div>
        <div class="tm-body">
          <div class="tm-name">{m.name}</div>
          <div class="tm-role">{m.role}</div>
          <p class="tm-bio">{m.bio}</p>

          <dl class="tm-quals">
            {m.quals.map((q) => (
              <div>
                <dt>{q.split(" ")[0]} {q.split(" ")[1] ?? ""}</dt>
                <dd>{q.split(" ").slice(2).join(" ") || q}</dd>
              </div>
            ))}
          </dl>
        </div>
      </article>
    ))}
  </div>

  <div class="team-quote reveal">
    <blockquote>
      <p>"I don't count reps at you. I watch, I adjust, and I remember
      where you were last week. That's the whole job."</p>
      <footer>Emma, founder</footer>
    </blockquote>
    <a href="/bookings" class="team-cta">
      Book a class <span aria-hidden="true">→</span>
    </a>
  </div>
</section>
