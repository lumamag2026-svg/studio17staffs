---
import { portraits } from "../data/images";

const emma = {
  name: "Emma",
  role: "Founder · Instructor",
  photo: portraits[0],
};
---

<section class="py-28 bg-cream-deep/60 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 lg:px-10">
    <div class="max-w-2xl reveal">
      <div class="text-xs uppercase tracking-[0.25em] text-sage-deep">Your teacher</div>
      <h2 class="mt-4 text-4xl md:text-6xl">One teacher. Every class. Your name, remembered.</h2>
    </div>

    <div class="mt-16 grid md:grid-cols-[1fr_1.1fr] gap-10 lg:gap-16 items-center">
      <article class="relative reveal">
        <div class="aspect-[4/5] rounded-3xl bg-gradient-to-br from-sage/30 via-clay/20 to-cream overflow-hidden">
          <img
            src={emma.photo}
            alt={`Portrait of ${emma.name}`}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="absolute -bottom-6 -right-6 rounded-2xl bg-cream p-5 shadow-xl shadow-ink/5 max-w-[240px]">
          <div class="text-xs uppercase tracking-widest text-sage-deep">Since 2022</div>
          <div class="mt-1 font-display text-lg leading-tight">Level 4 reformer · 8 years teaching.</div>
        </div>
      </article>

      <div class="reveal">
        <div class="font-display text-5xl md:text-6xl">{emma.name}</div>
        <div class="mt-2 text-sage-deep">{emma.role}</div>

        <div class="mt-8 space-y-5 text-ink-soft leading-relaxed">
          <p>
            Studio 17 is Emma's studio. She opened it in 2022 to teach the way she wished she'd been taught. Small classes, careful cues, and no one left in the back row.
          </p>
          <p>
            Every class you book, she teaches. There's no rotating roster of instructors, no substitutes to get used to. You'll see the same face on Monday morning as you do on Saturday, and she'll remember where you were last week.
          </p>
          <p>
            Emma holds Level 4 reformer qualifications and is trained in prenatal, postnatal, and rehabilitative pilates.
          </p>
        </div>

        <a href="/bookings" class="mt-10 inline-flex items-center gap-2 rounded-full bg-ink text-cream px-7 py-3.5 text-sm font-medium hover:bg-sage-deep transition">
          Book a class with Emma
          <span aria-hidden>→</span>
        </a>
      </div>
    </div>
  </div>
</section>
