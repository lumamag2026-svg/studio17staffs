---
---

<section class="contact" id="contact">
  <div class="sec-label reveal">
    <span class="num">06 / Write</span>
    <h2>Say <em>hello</em>.<br>We'll answer in a day.</h2>
  </div>

  <div class="contact-grid reveal">
    <!-- Left: info -->
    <div class="contact-info">
      <div class="contact-block">
        <div class="k">Email</div>
        <a class="v" href="mailto:hello@studio17staffs.co.uk">hello@studio17staffs.co.uk</a>
      </div>
      <div class="contact-block">
        <div class="k">Phone</div>
        <a class="v" href="tel:01782000017">01782 000 017</a>
      </div>
      <div class="contact-block">
        <div class="k">Studio</div>
        <p class="v-body">Paragon Avenue<br>Westbury Park, Staffordshire<br>ST5 4EX</p>
      </div>
      <div class="contact-block">
        <div class="k">Hours</div>
        <p class="v-body">Mon to Fri · 06:30 to 20:00<br>Sat to Sun · 08:00 to 14:00</p>
      </div>
      <div class="contact-aside">
        <p>
          For bookings, use the <a href="/bookings">calendar</a>. For press,
          partnership or privates, write directly to <a href="mailto:emma@studio17staffs.co.uk">emma@studio17staffs.co.uk</a>.
        </p>
      </div>
    </div>

    <!-- Right: form -->
    <form class="contact-form" id="contact-form">
      <div class="book-field">
        <label>Your name</label>
        <input required name="name" placeholder="Jane Doe" />
      </div>
      <div class="book-field">
        <label>Email</label>
        <input required type="email" name="email" placeholder="jane@email.com" />
      </div>
      <div class="book-field">
        <label>About</label>
        <select required name="topic">
          <option>General question</option>
          <option>Booking a private</option>
          <option>Pre/postnatal</option>
          <option>Injury / rehab</option>
          <option>Gift a class</option>
          <option>Press / partnership</option>
        </select>
      </div>
      <div class="book-field">
        <label>Message</label>
        <textarea required name="message" rows="6" placeholder="A few words…"></textarea>
      </div>

      <div class="book-actions" style="justify-content: flex-end">
        <button type="submit" class="book-btn" style="flex: 0 1 auto; padding-inline: 32px">Send message</button>
      </div>

      <div id="contact-ok" class="contact-ok" hidden>
        <div class="check">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12L10 17L19 7" stroke="currentColor" stroke-width="1.5"/></svg>
        </div>
        <div>
          <div class="v">Sent. Thank you.</div>
          <div class="sm">We'll reply within one working day.</div>
        </div>
      </div>
    </form>
  </div>
</section>

<script is:inline>
  const cf = document.getElementById("contact-form");
  cf?.addEventListener("submit", (e) => {
    e.preventDefault();
    cf.querySelectorAll("input, select, textarea, button").forEach((el) => (el.disabled = true));
    document.getElementById("contact-ok").hidden = false;
  });
</script>
