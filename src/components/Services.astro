---
import { pricing } from "../data/schedule";

const services = [
  { num: "01", name: "Foundations", emph: "Beginner", meta: "Group", max: "Max 3", dur: "45 minutes", price: pricing.single, unit: "per class" },
  { num: "02", name: "Progressions", emph: "Intermediate", meta: "Group", max: "Max 3", dur: "45 minutes", price: pricing.single, unit: "per class" },
  { num: "03", name: "Master", emph: "Class", meta: "Group", max: "Max 3", dur: "45 minutes", price: pricing.single, unit: "per class" },
  { num: "04", name: "Private", emph: "1:1", meta: "Format", max: "1 person", dur: "60 minutes", price: pricing.privateOne, unit: "per session" },
  { num: "05", name: "Private", emph: "1:2", meta: "Format", max: "2 people", dur: "60 minutes", price: pricing.privateTwo, unit: "per session" },
  { num: "06", name: "Sunday", emph: "Bootcamp", meta: "Course", max: "6 weeks", dur: "45 min · weekly", price: pricing.bootcamp, unit: "ask for price" },
];
---

<section class="services tint" id="classes">
  <div class="sec-label reveal">
    <span class="num">02 / Method</span>
    <h2>Six ways to <em>move</em>.<br>Pick where you're at.</h2>
  </div>

  <ul class="svc-list reveal">
    {services.map((s) => (
      <li class="svc-row">
        <span class="svc-num">{s.num}</span>
        <span class="svc-name">{s.name} <em>{s.emph}</em></span>
        <span class="svc-meta">{s.meta}<b>{s.max}</b></span>
        <span class="svc-meta">Duration<b>{s.dur}</b></span>
        <span class="svc-price">{s.price}<small>{s.unit}</small></span>
        <span class="svc-arrow">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.2"/></svg>
        </span>
      </li>
    ))}
  </ul>

  <div class="svc-packs reveal">
    <div class="pack">
      <div class="pack-k">5 Class Pack</div>
      <div class="pack-v">£95<small>save £2.50</small></div>
    </div>
    <div class="pack">
      <div class="pack-k">10 Class Pack</div>
      <div class="pack-v">£180<small>save £15</small></div>
    </div>
    <div class="pack">
      <div class="pack-k">Gift Vouchers</div>
      <div class="pack-v">Available<small>any value · ask in studio</small></div>
    </div>
  </div>
</section>
