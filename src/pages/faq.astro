---
import Layout from "../layouts/Layout.astro";

const faqs = [
  {
    q: "I've never done reformer pilates. Where do I start?",
    a: "The Foundations class is built for first-timers. You'll learn the bed, the springs, and the basic repertoire before we move you into Progressions. Or book a Private 1:1 if you'd rather find your feet one-on-one.",
  },
  {
    q: "What should I wear?",
    a: "Fitted activewear (loose drawstrings can catch on springs), grip socks (£5 at the studio if you forget), hair tied up, and a water bottle. We sell water at the studio for £1 if you forget that too.",
  },
  {
    q: "How early should I arrive?",
    a: "Ten minutes early. If you're earlier than that, please wait outside, another class will be running. Doors lock when class starts, so being on time matters.",
  },
  {
    q: "What's the cancellation policy?",
    a: "24 hours' notice to move a class to another slot. Inside 24 hours, the credit is lost.",
  },
  {
    q: "Do you teach pregnancy or postnatal classes?",
    a: "Not at the moment. We do not teach during pregnancy.",
  },
  {
    q: "Are there limits I should know about?",
    a: "Yes. The reformer beds have a 130kg weight limit and a 6'3\" height limit. Studio is adults only.",
  },
  {
    q: "Can I book 1:1 or 1:2 sessions?",
    a: "Yes. Private 1:1 is £30, 1:2 is £50. Sixty minutes. Get in touch via the contact form.",
  },
  {
    q: "What's the bootcamp?",
    a: "A six-week Sunday course combining one reformer class, two home workouts a week, nutrition advice, weekly Q&A and a private WhatsApp group. Pricing on request.",
  },
  {
    q: "Where do I park?",
    a: "On the road outside the studio. Door is on the side of the house.",
  },
  {
    q: "Toilet?",
    a: "There's one in the main house. Phoebe the lab lives there but is kept away from the studio. She barks but is harmless.",
  },
];
---

<Layout title="FAQ · Studio 17">
  <section class="pt-20 pb-28">
    <div class="max-w-3xl mx-auto px-6 lg:px-10">
      <div class="reveal">
        <div class="text-xs uppercase tracking-[0.25em] text-sage-deep">Questions, answered</div>
        <h1 class="mt-4 text-5xl md:text-7xl">FAQ</h1>
      </div>

      <div class="mt-16 divide-y divide-ink/10 border-y border-ink/10">
        {faqs.map((f) => (
          <details class="group py-6 reveal">
            <summary class="flex items-center justify-between gap-6 cursor-pointer list-none">
              <span class="font-display text-xl md:text-2xl">{f.q}</span>
              <span class="w-8 h-8 shrink-0 rounded-full border border-ink/20 flex items-center justify-center transition group-open:rotate-45">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <p class="mt-4 text-ink-soft leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>

      <p class="mt-16 text-ink-soft reveal">
        Can't find your answer? <a href="/#contact" class="underline underline-offset-4 text-ink hover:text-sage-deep">Send us a message</a>.
      </p>
    </div>
  </section>
</Layout>
